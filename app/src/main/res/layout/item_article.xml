<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/_9sdp"
    android:layout_marginVertical="@dimen/_6sdp"
    app:cardCornerRadius="@dimen/_16sdp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutline">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- News Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/newsImage"
            android:layout_width="0dp"
            android:layout_height="@dimen/_180sdp"
            android:scaleType="centerCrop"
            android:src="@drawable/news_placeholder"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Gradient Overlay -->
        <View
            android:id="@+id/imageOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/black_gradient_overlay"
            app:layout_constraintTop_toTopOf="@id/newsImage"
            app:layout_constraintBottom_toBottomOf="@id/newsImage"
            app:layout_constraintStart_toStartOf="@id/newsImage"
            app:layout_constraintEnd_toEndOf="@id/newsImage"/>

        <!-- Category Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/categoryChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Technology"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:layout_margin="12dp"
            android:backgroundTint="#66000000"
            app:chipCornerRadius="12dp"
            app:layout_constraintTop_toTopOf="@id/newsImage"
            app:layout_constraintStart_toStartOf="@id/newsImage"/>

        <!-- Title Over Image -->
        <TextView
            android:id="@+id/newsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:maxLines="2"
            android:ellipsize="end"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="@id/newsImage"
            app:layout_constraintStart_toStartOf="@id/newsImage"
            app:layout_constraintEnd_toEndOf="@id/newsImage"/>

        <!-- Summary -->
        <TextView
            android:id="@+id/newsSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:maxLines="2"
            android:ellipsize="end"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/newsImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Meta Info -->
        <TextView
            android:id="@+id/newsMeta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/newsSummary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>